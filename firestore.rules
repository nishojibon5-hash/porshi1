rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // 1. Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isMasterAdmin() { return isSignedIn() && request.auth.token.email == "salman1000790@gmail.com"; }
    
    function isAdmin() { 
      return isMasterAdmin() || 
             (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin');
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-.]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return (!('uid' in data) || (data.uid == request.auth.uid)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100)) &&
             (!('isOnline' in data) || data.isOnline is bool) &&
             (!('photoURL' in data) || (data.photoURL is string || data.photoURL == null)) &&
             (!('coverPhotoURL' in data) || (data.coverPhotoURL is string || data.coverPhotoURL == null)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000)) &&
             (!('role' in data) || data.role in ['user', 'admin']) &&
             (!('autoplayVideos' in data) || data.autoplayVideos is bool) &&
             (!('followersCount' in data) || data.followersCount is number) &&
             (!('followingCount' in data) || data.followingCount is number);
    }

    function isValidFollow(data) {
      return data.followerUid is string && isValidId(data.followerUid) &&
             data.followedUid is string && isValidId(data.followedUid) &&
             data.timestamp is timestamp;
    }

    function isValidPost(data) {
      return data.authorUid == request.auth.uid &&
             data.authorName is string && data.authorName.size() > 0 &&
             (!('content' in data) || (data.content is string && data.content.size() <= 10000)) &&
             data.likesCount is number &&
             data.commentsCount is number &&
             data.timestamp is timestamp;
    }

    // 3. Match Blocks
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) && isValidUser(incoming()) && incoming().keys().hasAll(['uid', 'displayName', 'isOnline']);
      allow update: if (
        (isOwner(uid) && (
          // Master admin can touch anything, others can't touch role/isMonetized
          isMasterAdmin() || !incoming().diff(existing()).affectedKeys().hasAny(['role', 'isMonetized'])
        )) ||
        isAdmin() ||
        // Allow public to increment follower counts
        incoming().diff(existing()).affectedKeys().hasOnly(['followersCount', 'followingCount'])
      ) && (
        // During self-update, validate everything. During count update, we assume existing doc is okay
        isOwner(uid) ? isValidUser(incoming()) : true
      );
    }

    match /users/{uid}/followers/{followerUid} {
      allow read: if true;
      allow create: if isOwner(followerUid) && isValidFollow(incoming()) && isValidId(uid);
      allow delete: if isOwner(followerUid);
    }

    match /users/{uid}/following/{followedUid} {
      allow read: if true;
      allow create: if isOwner(uid) && isValidFollow(incoming()) && isValidId(followedUid);
      allow delete: if isOwner(uid);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isEmailVerified() && isValidPost(incoming());
      allow update: if isSignedIn() && (
        isOwner(existing().authorUid) || 
        isAdmin() ||
        // Public counters
        incoming().diff(existing()).affectedKeys().hasAny(['likesCount', 'commentsCount', 'reactions', 'reachCount', 'viewsCount'])
      );
      allow delete: if isOwner(existing().authorUid) || isAdmin();
    }

    match /posts/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if isEmailVerified() && incoming().authorUid == request.auth.uid;
      allow delete: if isOwner(existing().authorUid) || isAdmin() || isOwner(get(/databases/$(database)/documents/posts/$(postId)).data.authorUid);
    }

    match /posts/{postId}/likes/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    match /posts/{postId}/userReactions/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    match /posts/{postId}/comments/{commentId}/userReactions/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in chatId.split('_'));
      allow create: if isSignedIn() && incoming().senderUid == request.auth.uid;
    }

    match /conversations/{userId}/userChats/{partnerId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) || isOwner(partnerId);
    }

    match /chats/{chatId}/typing/{uid} {
      allow read: if isSignedIn() && (request.auth.uid in chatId.split('_'));
      allow write: if isOwner(uid) && (uid in chatId.split('_'));
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(existing().toUid) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isOwner(existing().toUid) || isAdmin();
    }

    // Additional collections based on code scan
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isEmailVerified() && incoming().authorUid == request.auth.uid;
      allow delete: if isOwner(existing().authorUid) || isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow create: if isEmailVerified();
      allow update: if isAdmin() || isOwner(existing().creatorId) || incoming().diff(existing()).affectedKeys().hasOnly(['reach', 'clicks']);
      allow delete: if isAdmin() || isOwner(existing().creatorId);
    }

    match /monetization/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['totalEarnings', 'engagement']);
    }

    match /requests/{requestId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if isEmailVerified() && incoming().fromUid == request.auth.uid;
      allow update: if isSignedIn() && request.auth.uid == resource.data.toUid && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
