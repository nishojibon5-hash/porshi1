// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid}
// Fields:
//   - uid: string (required)
//   - displayName: string (required)
//   - photoURL: string (optional)
//   - isOnline: boolean (required)
//   - lastSeen: timestamp (optional)
//
// Collection: posts
// Document ID: {postId}
// Fields:
//   - authorUid: string (required)
//   - authorName: string (required)
//   - authorPhoto: string (optional)
//   - content: string (required)
//   - imageUrl: string (optional)
//   - likesCount: number (required)
//   - commentsCount: number (required)
//   - timestamp: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          request.auth.token.email == "salman1000790@gmail.com");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isMasterAdmin() {
      return isAuthenticated() && request.auth.token.email == "salman1000790@gmail.com";
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string && 
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.isOnline is bool &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('lastSeen' in data) || data.lastSeen is timestamp) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 2000)) &&
             (!('role' in data) || data.role in ['user', 'admin']) &&
             (!('isMonetized' in data) || data.isMonetized is bool) &&
             (!('lastLat' in data) || data.lastLat is number) &&
             (!('lastLng' in data) || data.lastLng is number) &&
             (!('isDiscoverable' in data) || data.isDiscoverable is bool) &&
             (!('discoveryStatus' in data) || (data.discoveryStatus is string && data.discoveryStatus.size() < 200)) &&
             (!('followersCount' in data) || data.followersCount is number) &&
             (!('followingCount' in data) || data.followingCount is number);
    }

    function isValidFollow(data) {
      return data.followerUid is string &&
             data.followedUid is string &&
             data.timestamp is timestamp;
    }

    function isValidPost(data) {
      return data.authorUid == request.auth.uid &&
             data.authorName is string &&
             (!('content' in data) || (data.content is string && data.content.size() < 5000)) &&
             data.likesCount is number &&
             data.commentsCount is number &&
             data.timestamp is timestamp &&
             (!('reactions' in data) || data.reactions is map);
    }

    function isValidMonetization(data) {
      return data.totalEarnings is number &&
             data.reach is number &&
             data.engagement is number &&
             data.followers is number;
    }

    function isValidComment(data) {
      return data.authorUid == request.auth.uid &&
             data.authorName is string &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.timestamp is timestamp;
    }

    function isValidLike(data) {
      return data.userUid == request.auth.uid &&
             data.timestamp is timestamp;
    }

    function isValidStory(data) {
      return data.authorUid == request.auth.uid &&
             data.authorName is string &&
             data.imageUrl is string &&
             data.timestamp is timestamp &&
             data.expiresAt is timestamp;
    }

    function isValidNotification(data) {
      return (data.toUid is string && data.toUid.size() > 0) &&
             data.type in ['like', 'comment', 'follow', 'system', 'link', 'event', 'message', 'pair_request'] &&
             data.title is string && data.title.size() > 0 &&
             data.message is string &&
             data.isRead is bool &&
             data.timestamp is timestamp;
    }

    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (
        (isOwner(uid) && (
          // Allow owner to update EXCEPT role/isMonetized unless they are master admin
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isMonetized'])) || isMasterAdmin()
        )) ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['followersCount', 'followingCount'])
      ) && isValidUser(request.resource.data);
    }

    match /users/{uid}/followers/{followerUid} {
      allow read: if true;
      allow create, delete: if isOwner(followerUid) && isValidFollow(request.resource.data);
    }

    match /users/{uid}/following/{followedUid} {
      allow read: if true;
      allow create, delete: if isOwner(uid) && isValidFollow(request.resource.data);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && 
                    (isOwner(resource.data.authorUid) || 
                     request.resource.data.diff(resource.data).affectedKeys().hasAny(['likesCount', 'commentsCount', 'reactions']));
      allow delete: if isOwner(resource.data.authorUid);
    }

    match /monetization/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isValidMonetization(request.resource.data);
    }

    match /posts/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow delete: if isOwner(resource.data.authorUid);
    }

    match /posts/{postId}/likes/{uid} {
      allow read: if true;
      allow create, delete: if isOwner(uid);
    }

    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidStory(request.resource.data);
      allow delete: if isOwner(resource.data.authorUid);
    }

    match /requests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if isAuthenticated() && (request.resource.data.fromUid == request.auth.uid);
      allow update: if isAuthenticated() && 
                    (request.auth.uid == resource.data.toUid) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid in chatId.split('_'));
      allow create: if isAuthenticated() && (request.resource.data.senderUid == request.auth.uid);
    }

    match /chats/{chatId}/typing/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid in chatId.split('_'));
      allow create, update: if isOwner(uid);
    }

    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.toUid == request.auth.uid || resource.data.toUid == 'all');
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.toUid == request.auth.uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.toUid == request.auth.uid);
    }
  }
}
