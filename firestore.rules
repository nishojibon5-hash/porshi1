// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid}
// Fields:
//   - uid: string (required)
//   - displayName: string (required)
//   - isOnline: boolean (required)
//   - lastSeen: timestamp (optional)
//
// Collection: requests
// Document ID: {requestId}
// Fields:
//   - fromUid: string (required)
//   - fromName: string (required)
//   - toUid: string (required)
//   - toName: string (required)
//   - status: string (required, ['pending', 'accepted', 'declined'])
//   - timestamp: timestamp (required)
//
// Collection: chats/{chatId}/messages
// Document ID: {messageId}
// Fields:
//   - senderUid: string (required)
//   - text: string (required)
//   - timestamp: timestamp (required)
//   - pairId: string (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string && 
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.isOnline is bool;
    }

    function isValidRequest(data) {
      return data.fromUid == request.auth.uid &&
             data.fromName is string &&
             data.toUid is string &&
             data.toName is string &&
             data.status in ['pending', 'accepted', 'declined'] &&
             data.timestamp is timestamp;
    }

    function isValidMessage(data) {
      return data.senderUid == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.timestamp is timestamp &&
             data.pairId is string &&
             (!('isRead' in data) || data.isRead is bool);
    }

    function isValidTyping(data) {
      return data.isTyping is bool &&
             data.timestamp is timestamp;
    }

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(uid) && isValidUser(request.resource.data);
    }

    match /requests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if isAuthenticated() && isValidRequest(request.resource.data);
      allow update: if isAuthenticated() && 
                    (request.auth.uid == resource.data.toUid) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                    request.resource.data.status in ['accepted', 'declined'];
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow update: if isAuthenticated() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']) &&
                    request.resource.data.isRead == true;
    }

    match /chats/{chatId}/typing/{uid} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(uid) && isValidTyping(request.resource.data);
    }
  }
}
