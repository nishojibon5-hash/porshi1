{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user profile and status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "followersCount": { "type": "number" },
        "followingCount": { "type": "number" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "isMonetized": { "type": "boolean" },
        "bio": { "type": "string" },
        "lastLat": { "type": "number" },
        "lastLng": { "type": "number" },
        "isDiscoverable": { "type": "boolean" },
        "discoveryStatus": { "type": "string" }
      },
      "required": ["uid", "displayName", "isOnline"]
    },
    "Follow": {
      "title": "Follow",
      "description": "Relationship between follower and followed user",
      "type": "object",
      "properties": {
        "followerUid": { "type": "string" },
        "followedUid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["followerUid", "followedUid", "timestamp"]
    },
    "PairRequest": {
      "title": "PairRequest",
      "description": "Request to pair with another user",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "fromName": { "type": "string" },
        "toUid": { "type": "string" },
        "toName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUid", "fromName", "toUid", "toName", "status"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Message in a chat session",
      "type": "object",
      "properties": {
        "senderUid": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "pairId": { "type": "string" },
        "isRead": { "type": "boolean" }
      },
      "required": ["senderUid", "text", "pairId"]
    },
    "TypingStatus": {
      "title": "TypingStatus",
      "description": "Real-time typing indicator",
      "type": "object",
      "properties": {
        "isTyping": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["isTyping"]
    },
    "Post": {
      "title": "Post",
      "description": "Social media post",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "reactions": { 
          "type": "object",
          "properties": {
            "like": { "type": "number" },
            "love": { "type": "number" },
            "haha": { "type": "number" },
            "wow": { "type": "number" },
            "sad": { "type": "number" },
            "angry": { "type": "number" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "isMonetized": { "type": "boolean" },
        "viewsCount": { "type": "number" },
        "reachCount": { "type": "number" },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "videoUrl": { "type": "string" }
      },
      "required": ["authorUid", "authorName", "content", "timestamp"]
    },
    "Monetization": {
      "title": "Monetization",
      "description": "User monetization statistics",
      "type": "object",
      "properties": {
        "totalEarnings": { "type": "number" },
        "monthlyEarnings": { "type": "number" },
        "reach": { "type": "number" },
        "engagement": { "type": "number" },
        "followers": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["totalEarnings", "reach", "engagement", "followers"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Comment on a post",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "authorName", "text", "timestamp"]
    },
    "Like": {
      "title": "Like",
      "description": "Like on a post",
      "type": "object",
      "properties": {
        "userUid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userUid", "timestamp"]
    },
    "Story": {
      "title": "Story",
      "description": "Short-lived story",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "authorName", "imageUrl", "timestamp", "expiresAt"]
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "Dynamic application configuration",
      "type": "object",
      "properties": {
        "maintenanceMode": { "type": "boolean" },
        "welcomeMessage": { "type": "string" },
        "appVersion": { "type": "string" },
        "minVersion": { "type": "string" },
        "contactEmail": { "type": "string" },
        "announcement": { "type": "string" },
        "themeColor": { "type": "string" },
        "adPaidMode": { "type": "boolean" },
        "adPaymentNumber": { "type": "string" }
      }
    },
    "Advertisement": {
      "title": "Advertisement",
      "description": "Ad campaign details",
      "type": "object",
      "properties": {
        "advertiserUid": { "type": "string" },
        "advertiserName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "objective": { "type": "string", "enum": ["views", "likes", "comments", "followers", "sales", "website_views"] },
        "location": { "type": "string" },
        "audience": { "type": "string" },
        "adType": { "type": "string", "enum": ["banner", "video_skippable"] },
        "videoAdUrl": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "durationDays": { "type": "number" },
        "budget": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "paused"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "reach": { "type": "number" },
        "clicks": { "type": "number" },
        "vastUrl": { "type": "string" },
        "vastType": { "type": "string", "enum": ["pre-roll", "mid-roll", "post-roll"] }
      },
      "required": ["advertiserUid", "title", "status", "paymentStatus"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles and online status"
    },
    "/requests/{requestId}": {
      "schema": "PairRequest",
      "description": "Pairing requests between users"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages for a specific chat session"
    },
    "/chats/{chatId}/typing/{uid}": {
      "schema": "TypingStatus",
      "description": "Typing indicators for users in a chat"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Social media posts"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a post"
    },
    "/posts/{postId}/likes/{uid}": {
      "schema": "Like",
      "description": "Likes on a post"
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "User stories"
    },
    "/monetization/{uid}": {
      "schema": "Monetization",
      "description": "User monetization stats"
    },
    "/users/{uid}/followers/{followerUid}": {
      "schema": "Follow",
      "description": "Users following a specific user"
    },
    "/users/{uid}/following/{followedUid}": {
      "schema": "Follow",
      "description": "Users followed by a specific user"
    },
    "/appConfig/{configId}": {
      "schema": "AppConfig",
      "description": "Dynamic app remote configuration"
    },
    "/ads/{adId}": {
      "schema": "Advertisement",
      "description": "Advertisement campaigns"
    }
  }
}
