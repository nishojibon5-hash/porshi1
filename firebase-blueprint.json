{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user profile and status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "isOnline"]
    },
    "PairRequest": {
      "title": "PairRequest",
      "description": "Request to pair with another user",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "fromName": { "type": "string" },
        "toUid": { "type": "string" },
        "toName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUid", "fromName", "toUid", "toName", "status"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Message in a chat session",
      "type": "object",
      "properties": {
        "senderUid": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "pairId": { "type": "string" },
        "isRead": { "type": "boolean" }
      },
      "required": ["senderUid", "text", "pairId"]
    },
    "TypingStatus": {
      "title": "TypingStatus",
      "description": "Real-time typing indicator",
      "type": "object",
      "properties": {
        "isTyping": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["isTyping"]
    },
    "Post": {
      "title": "Post",
      "description": "Social media post",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "reactions": { 
          "type": "object",
          "properties": {
            "like": { "type": "number" },
            "love": { "type": "number" },
            "haha": { "type": "number" },
            "wow": { "type": "number" },
            "sad": { "type": "number" },
            "angry": { "type": "number" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "authorName", "content", "timestamp"]
    },
    "Monetization": {
      "title": "Monetization",
      "description": "User monetization statistics",
      "type": "object",
      "properties": {
        "totalEarnings": { "type": "number" },
        "monthlyEarnings": { "type": "number" },
        "reach": { "type": "number" },
        "engagement": { "type": "number" },
        "followers": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["totalEarnings", "reach", "engagement", "followers"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Comment on a post",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "authorName", "text", "timestamp"]
    },
    "Like": {
      "title": "Like",
      "description": "Like on a post",
      "type": "object",
      "properties": {
        "userUid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userUid", "timestamp"]
    },
    "Story": {
      "title": "Story",
      "description": "Short-lived story",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "authorName", "imageUrl", "timestamp", "expiresAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles and online status"
    },
    "/requests/{requestId}": {
      "schema": "PairRequest",
      "description": "Pairing requests between users"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages for a specific chat session"
    },
    "/chats/{chatId}/typing/{uid}": {
      "schema": "TypingStatus",
      "description": "Typing indicators for users in a chat"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Social media posts"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a post"
    },
    "/posts/{postId}/likes/{uid}": {
      "schema": "Like",
      "description": "Likes on a post"
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "User stories"
    },
    "/monetization/{uid}": {
      "schema": "Monetization",
      "description": "User monetization stats"
    }
  }
}
